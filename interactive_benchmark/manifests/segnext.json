{
  "method_id": "segnext",
  "display_name": "SegNext",
  "prompt_type": "point",
  "paper_url": "https://openaccess.thecvf.com/content/CVPR2024/papers/Liu_Rethinking_Interactive_Image_Segmentation_with_Low_Latency_High_Quality_and_CVPR_2024_paper.pdf",
  "repo_url": "https://github.com/uncbiag/SegNext",
  "commit": "db045f6d6bab73029457e2ced4fec4a92cc69600",
  "weights": "https://drive.google.com/uc?id=1qkXIvxnlY3Z4xLYGWJcoAHBUNyDmvwPS",
  "required_paths": [
    "{repo_root}/.venv/bin/python",
    "{repo_root}/interactive_benchmark/runners/segnext_runner.py"
  ],
  "runtime": {
    "cwd": "{repo_root}",
    "env": {}
  },
  "inference": {
    "checkpoint_path": "{repo_root}/.external_sources/segnext/weights/vitb_sa2_cocolvis_hq44k_epoch_0.pth",
    "device": "auto",
    "prob_thresh": 0.5
  },
  "entrypoint": {
    "command": [
      "{repo_root}/.venv/bin/python",
      "{repo_root}/interactive_benchmark/runners/segnext_runner.py",
      "--input-json",
      "{input_json}",
      "--output-json",
      "{output_json}"
    ]
  }
}
